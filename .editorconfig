# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# TypeScript/JavaScript
[*.ts]
indent_size = 2
[*.tsx]
indent_size = 2
[*.js]
indent_size = 2
[*.jsx]
indent_size = 2

# JSON/YAML
[*.json]
indent_size = 2
[*.yml]
indent_size = 2
[*.yaml]
indent_size = 2

# Go
[*.go]
indent_style = tab
indent_size = 4

# Rust
[*.rs]
indent_style = space
indent_size = 4

# Java
[*.java]
indent_style = space
indent_size = 4

# C#
[*.cs]
indent_style = space
indent_size = 4
