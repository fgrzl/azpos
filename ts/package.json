{
  "name": "azpos",
  "version": "1.0.0",
  "description": "TypeScript implementation of lexicographic position calculations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write .",
    "clean": "rimraf dist"
  },
  "keywords": [
    "lexicographic",
    "fractional-indexing",
    "crdt",
    "position",
    "midpoint",
    "typescript",
    "library",
    "order",
    "collaboration",
    "distributed",
    "string-sorting"
  ],
  "author": "smiggleworth",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist/**/*"
  ]
}
